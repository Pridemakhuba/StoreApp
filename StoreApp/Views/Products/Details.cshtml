@* Views/Products/Details.cshtml *@
@model StoreApp.Models.Product
@{ ViewData["Title"] = "Product Details"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="py-4 px-3">
    <h2>📦 @Model.ProductName</h2><hr />
    <dl class="row">
        <dt class="col-sm-3">Product ID</dt>  <dd class="col-sm-9">@Model.ProductID</dd>
        <dt class="col-sm-3">Category</dt>    <dd class="col-sm-9">@Model.Category?.CategoryName</dd>
        <dt class="col-sm-3">Description</dt> <dd class="col-sm-9">@Model.Description</dd>
        <dt class="col-sm-3">Price</dt>       <dd class="col-sm-9">R @Model.Price.ToString("N2")</dd>
        <dt class="col-sm-3">Stock Qty</dt>   <dd class="col-sm-9">@Model.StockQty</dd>
        <dt class="col-sm-3">Active</dt>      <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
        <dt class="col-sm-3">Created</dt>     <dd class="col-sm-9">@Model.CreatedDate.ToString("dd MMM yyyy")</dd>
    </dl>
    <a asp-action="Edit" asp-route-id="@Model.ProductID" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
</div>

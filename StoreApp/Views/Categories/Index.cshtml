@* ── Views/Categories/Index.cshtml ──────────────────────── *@
@model IEnumerable<StoreApp.Models.Category>
@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<div class="py-4 px-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>📂 Categories</h2>
        <a class="btn btn-primary" asp-action="Create">+ New Category</a>
    </div>
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-dark">
            <tr><th>ID</th><th>Name</th><th>Description</th><th>Active</th><th>Created</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.CategoryID</td>
                <td>@c.CategoryName</td>
                <td>@c.Description</td>
                <td>@(c.IsActive ? "✅" : "❌")</td>
                <td>@c.CreatedDate.ToString("dd MMM yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.CategoryID" class="btn btn-sm btn-outline-info">View</a>
                    <a asp-action="Edit"    asp-route-id="@c.CategoryID" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete"  asp-route-id="@c.CategoryID" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

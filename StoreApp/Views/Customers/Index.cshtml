@* Views/Customers/Index.cshtml *@
@model IEnumerable<StoreApp.Models.Customer>
@{ ViewData["Title"] = "Customers"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="py-4 px-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>👤 Customers</h2>
        <a class="btn btn-primary" asp-action="Create">+ New Customer</a>
    </div>
    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4"><input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search name or email..." /></div>
        <div class="col-auto"><button type="submit" class="btn btn-outline-primary">Search</button></div>
        <div class="col-auto"><a asp-action="Index" class="btn btn-outline-secondary">Clear</a></div>
    </form>
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-dark">
            <tr><th>ID</th><th>Full Name</th><th>Email</th><th>Phone</th><th>Joined</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.CustomerID</td>
                <td>@c.FullName</td>
                <td>@c.Email</td>
                <td>@c.Phone</td>
                <td>@c.CreatedDate.ToString("dd MMM yyyy")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@c.CustomerID" class="btn btn-sm btn-outline-info">View</a>
                    <a asp-action="Edit"    asp-route-id="@c.CustomerID" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete"  asp-route-id="@c.CustomerID" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>

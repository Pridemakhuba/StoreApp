@* Views/Orders/Details.cshtml *@
@model StoreApp.Models.Order
@{ ViewData["Title"] = "Order Details"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="py-4 px-3">
    <h2>🛒 Order #@Model.OrderID</h2><hr />
    <dl class="row">
        <dt class="col-sm-3">Customer</dt>   <dd class="col-sm-9">@Model.Customer?.FullName (@Model.Customer?.Email)</dd>
        <dt class="col-sm-3">Order Date</dt> <dd class="col-sm-9">@Model.OrderDate.ToString("dd MMM yyyy HH:mm")</dd>
        <dt class="col-sm-3">Status</dt>     <dd class="col-sm-9"><span class="badge @(Model.Status=="Completed"?"bg-success":Model.Status=="Shipped"?"bg-info text-dark":"bg-warning text-dark")">@Model.Status</span></dd>
        <dt class="col-sm-3">Notes</dt>      <dd class="col-sm-9">@Model.Notes</dd>
    </dl>
    <h5 class="mt-3">Order Items</h5>
    <table class="table table-bordered table-sm">
        <thead class="table-light"><tr><th>Product</th><th>Qty</th><th>Unit Price</th><th>Subtotal</th></tr></thead>
        <tbody>
        @foreach (var item in Model.OrderItems)
        {
            <tr>
                <td>@item.Product?.ProductName</td>
                <td>@item.Quantity</td>
                <td>R @item.UnitPrice.ToString("N2")</td>
                <td>R @item.Subtotal.ToString("N2")</td>
            </tr>
        }
        </tbody>
        <tfoot class="table-dark">
            <tr><td colspan="3" class="text-end fw-bold">Total</td><td>R @Model.TotalAmount.ToString("N2")</td></tr>
        </tfoot>
    </table>
    <a asp-action="AddItem" asp-route-orderId="@Model.OrderID" class="btn btn-success">+ Add Item</a>
    <a asp-action="Edit"    asp-route-id="@Model.OrderID"      class="btn btn-warning ms-2">Edit Order</a>
    <a asp-action="Index"                                       class="btn btn-secondary ms-2">Back</a>
</div>

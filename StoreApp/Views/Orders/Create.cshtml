@* Views/Orders/Create.cshtml *@
@model StoreApp.Models.Order
@{ ViewData["Title"] = "New Order"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="py-4 px-3" style="max-width:520px">
    <h2>➕ New Order</h2><hr />
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
        <div class="mb-3">
            <label asp-for="CustomerID" class="form-label">Customer</label>
            @Html.DropDownList("CustomerID", (SelectList)ViewBag.Customers, "-- Select Customer --", new { @class = "form-select" })
            <span asp-validation-for="CustomerID" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-label"></label>
            <select asp-for="Status" class="form-select">
                <option>Pending</option><option>Processing</option><option>Shipped</option><option>Completed</option><option>Cancelled</option>
            </select>
        </div>
        <div class="mb-3"><label asp-for="Notes" class="form-label"></label><textarea asp-for="Notes" class="form-control" rows="2"></textarea></div>
        <button type="submit" class="btn btn-primary">Create & Add Items →</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>

@* Views/Orders/Edit.cshtml *@
@model StoreApp.Models.Order
@{ ViewData["Title"] = "Edit Order"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="py-4 px-3" style="max-width:520px">
    <h2>✏️ Edit Order #@Model.OrderID</h2><hr />
    <form asp-action="Edit" asp-controller="Orders" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="OrderID" />
        <input type="hidden" asp-for="OrderDate" />
        <input type="hidden" asp-for="TotalAmount" />

        <div class="mb-3">
            <label asp-for="CustomerID" class="form-label fw-semibold">Customer</label>
            <select asp-for="CustomerID" class="form-select" name="CustomerID">
                @foreach (SelectListItem item in (SelectList)ViewBag.Customers)
                {
                    <option value="@item.Value" selected="@item.Selected">@item.Text</option>
                }
            </select>
            <span asp-validation-for="CustomerID" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Status" class="form-label fw-semibold">Status</label>
            <select asp-for="Status" class="form-select" name="Status">
                <option value="Pending"    selected="@(Model.Status == "Pending"    ? "selected" : null)">Pending</option>
                <option value="Processing" selected="@(Model.Status == "Processing" ? "selected" : null)">Processing</option>
                <option value="Shipped"    selected="@(Model.Status == "Shipped"    ? "selected" : null)">Shipped</option>
                <option value="Completed"  selected="@(Model.Status == "Completed"  ? "selected" : null)">Completed</option>
                <option value="Cancelled"  selected="@(Model.Status == "Cancelled"  ? "selected" : null)">Cancelled</option>
            </select>
        </div>

        <div class="mb-3">
            <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
            <textarea asp-for="Notes" class="form-control" rows="3" name="Notes"></textarea>
        </div>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

        <button type="submit" class="btn btn-warning px-4">Update Order</button>
        <a asp-action="Details" asp-route-id="@Model.OrderID" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>

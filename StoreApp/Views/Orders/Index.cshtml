@* Views/Orders/Index.cshtml *@
@model IEnumerable<StoreApp.Models.Order>
@{ ViewData["Title"] = "Orders"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<div class="py-4 px-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>🛒 Orders</h2>
        <a class="btn btn-primary" asp-action="Create">+ New Order</a>
    </div>
    <form method="get" class="row g-2 mb-3">
        <div class="col-auto">
            <select name="status" class="form-select">
                <option value="">All Statuses</option>
                @foreach (var s in ViewBag.Statuses) { <option value="@s" selected="@(ViewBag.SelectedStatus == s)">@s</option> }
            </select>
        </div>
        <div class="col-auto"><button type="submit" class="btn btn-outline-primary">Filter</button></div>
        <div class="col-auto"><a asp-action="Index" class="btn btn-outline-secondary">Clear</a></div>
    </form>
    <table class="table table-bordered table-hover bg-white">
        <thead class="table-dark">
            <tr><th>Order #</th><th>Customer</th><th>Date</th><th>Status</th><th>Total</th><th>Actions</th></tr>
        </thead>
        <tbody>
        @foreach (var o in Model)
        {
            <tr>
                <td>#@o.OrderID</td>
                <td>@o.Customer?.FullName</td>
                <td>@o.OrderDate.ToString("dd MMM yyyy")</td>
                <td><span class="badge @(o.Status=="Completed"?"bg-success":o.Status=="Shipped"?"bg-info text-dark":"bg-warning text-dark")">@o.Status</span></td>
                <td>R @o.TotalAmount.ToString("N2")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@o.OrderID" class="btn btn-sm btn-outline-info">View</a>
                    <a asp-action="Edit"    asp-route-id="@o.OrderID" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete"  asp-route-id="@o.OrderID" class="btn btn-sm btn-outline-danger">Delete</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
